rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Development-friendly rules ─────────────────────────────────────────
    // Allow any authenticated user full read/write access.
    // Replace with the stricter rules below before going to production.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    /* ── PRODUCTION RULES (uncomment when ready) ──────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuth() && userProfile().role == role;
    }

    function sameTenant(tenantId) {
      return isAuth() && userProfile().tenantId == tenantId;
    }

    match /users/{uid} {
      allow read: if isAuth() && (
        request.auth.uid == uid ||
        (sameTenant(resource.data.tenantId) && hasRole('admin'))
      );
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && (
        request.auth.uid == uid ||
        (sameTenant(resource.data.tenantId) && hasRole('admin'))
      );
      allow delete: if false;
    }

    match /tenants/{tenantId} {
      allow read: if isAuth() && userProfile().tenantId == tenantId;
      allow create: if isAuth();
      allow update: if isAuth() && userProfile().tenantId == tenantId && hasRole('admin');
      allow delete: if false;
    }

    match /employees/{employeeId} {
      allow read: if isAuth() && sameTenant(resource.data.tenantId);
      allow create: if isAuth() && sameTenant(request.resource.data.tenantId) &&
        (hasRole('admin') || hasRole('manager'));
      allow update: if isAuth() && sameTenant(resource.data.tenantId) &&
        (hasRole('admin') || hasRole('manager'));
      allow delete: if isAuth() && sameTenant(resource.data.tenantId) && hasRole('admin');
    }

    match /leads/{leadId} {
      allow read: if isAuth() && sameTenant(resource.data.tenantId);
      allow create: if isAuth() && sameTenant(request.resource.data.tenantId) &&
        (hasRole('admin') || hasRole('manager'));
      allow update: if isAuth() && sameTenant(resource.data.tenantId) &&
        (hasRole('admin') || hasRole('manager'));
      allow delete: if isAuth() && sameTenant(resource.data.tenantId) &&
        (hasRole('admin') || hasRole('manager'));
    }

    match /projects/{projectId} {
      allow read: if isAuth() && sameTenant(resource.data.tenantId);
      allow create: if isAuth() && sameTenant(request.resource.data.tenantId) &&
        (hasRole('admin') || hasRole('manager'));
      allow update: if isAuth() && sameTenant(resource.data.tenantId) &&
        (hasRole('admin') || hasRole('manager'));
      allow delete: if isAuth() && sameTenant(resource.data.tenantId) &&
        (hasRole('admin') || hasRole('manager'));

      match /tasks/{taskId} {
        allow read: if isAuth();
        allow create: if isAuth() && (hasRole('admin') || hasRole('manager'));
        allow update: if isAuth();
        allow delete: if isAuth() && (hasRole('admin') || hasRole('manager'));
      }
    }

    match /activity_logs/{logId} {
      allow read: if isAuth() && sameTenant(resource.data.tenantId);
      allow create: if isAuth() && sameTenant(request.resource.data.tenantId);
      allow update, delete: if false;
    }

    ── END PRODUCTION RULES ── */
  }
}
